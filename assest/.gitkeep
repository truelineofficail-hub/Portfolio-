  <title>Layout</title>
  <link rel="stylesheet" href="new.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
</head>
<body>
  <nav>
    <div class="navbar">
      <div id="logo">Portfolio</div>
      <ul class="nav-links">
        <li><a href="index.html">Home</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#Contact">Contact</a></li>
      </ul>
    </div>
  </nav>
  
  <main id="Home" class="main1-1">
    <div class="intro">
      <h1>Hi There! <br> I'm Harsh Rajput</h1>
      <div id="web">Web designer & Web developer</div>
      <div class="buttons">
        <a href="mailto:Truelineofficail@gmail.com?subject=Project%20Inquiry&body=Hi%20Harsh,%20I%20visited%20your%20portfolio%20and%20would%20like%20to%20discuss%20a%20project%20with%20you.">

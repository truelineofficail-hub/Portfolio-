  <main id="skills" class="main2">
    <div id="topic">Skills</div>
    
    <div class="card-container">
      <div class="skill-group">
        <div id="img1"></div>
        <div id="text-1" class="img-text">WEB DEVELOPMENT</div>
      </div>
      
      <div class="skill-group">
        <div id="img2"></div>
        <div id="text-3" class="img-text">WEBSITE SETUP</div>
      </div>
      
      <div class="skill-group">
        <div id="img3"></div>
        <div id="text-5" class="img-text">DESIGN TO CODE</div>
      </div>
    </div>
  </main>

  <main id="Contact" class="main3">
     <div class="footer-app">
        <a href="https://www.instagram.com/mey.harsh07?igsh=MWN5YTBkeWJwMmxzZg==" class="social" aria-label="Instagram"><i class="fa-brands fa-instagram"></i></a>
        <a href="https://github.com/truelineofficail-hub" class="social" aria-label="GitHub"><i class="fa-brands fa-github"></i></a>
